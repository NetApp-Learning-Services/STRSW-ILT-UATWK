        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.95, sum(rate(http_requests_duration_seconds_bucket{job=\"example-app\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "title": "95th Percentile Request Latency",
